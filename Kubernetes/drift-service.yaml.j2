apiVersion: apps/v1
kind: Deployment
metadata:
  name: drift-deployment
  namespace: log-anomaly
spec:
  replicas: 1
  selector:
    matchLabels:
      app: drift-service
  template:
    metadata:
      labels:
        app: drift-service
    spec:
      containers:
      - name: drift-service
        image: preet1018/drift-service:{{ drift_tag | default('latest') }}
        ports:
        - containerPort: 8001
        env:
        - name: PROJECT_ROOT
          value: "/app"
        - name: PREDICTION_SERVICE_URL
          value: "http://prediction-service:8000"
        - name: MONGO_USER
          valueFrom:
            secretKeyRef:
              name: mongodb-secret
              key: mongo-root-username
        - name: MONGO_PASS
          valueFrom:
            secretKeyRef:
              name: mongodb-secret
              key: mongo-root-password
        - name: MONGO_DB
          valueFrom:
            secretKeyRef:
              name: mongodb-secret
              key: mongo-initdb-database
        - name: MONGO_URI
          value: "mongodb://$(MONGO_USER):$(MONGO_PASS)@mongodb:27017/$(MONGO_DB)?authSource=admin"
        volumeMounts:
        - name: models-storage
          mountPath: /app/models
        - name: data-storage
          mountPath: /app/data_storage
      volumes:
      - name: models-storage
        persistentVolumeClaim:
          claimName: models-pvc
      - name: data-storage
        persistentVolumeClaim:
          claimName: data-pvc

---
apiVersion: v1
kind: Service
metadata:
  name: drift-service
  namespace: log-anomaly
spec:
  selector:
    app: drift-service
  type: ClusterIP

  ports:
    - protocol: TCP
      port: 8001
      targetPort: 8001
