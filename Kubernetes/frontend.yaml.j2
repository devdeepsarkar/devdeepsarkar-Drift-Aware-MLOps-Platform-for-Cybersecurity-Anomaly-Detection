apiVersion: apps/v1
kind: Deployment
metadata:
  name: frontend-deployment
  namespace: log-anomaly
spec:
  replicas: 1
  selector:
    matchLabels:
      app: frontend
  template:
    metadata:
      labels:
        app: frontend
    spec:
      containers:
      - name: frontend
        image: preet1018/frontend:{{ frontend_tag | default('latest') }}
        ports:
        - containerPort: 8501
        env:
        - name: API_URL
          value: "http://prediction-service:8000"
        - name: MONGO_USER
          valueFrom:
            secretKeyRef:
              name: mongodb-secret
              key: mongo-root-username
        - name: MONGO_PASS
          valueFrom:
            secretKeyRef:
              name: mongodb-secret
              key: mongo-root-password
        - name: MONGO_DB
          valueFrom:
            secretKeyRef:
              name: mongodb-secret
              key: mongo-initdb-database
        - name: MONGO_URI
          value: "mongodb://$(MONGO_USER):$(MONGO_PASS)@mongodb:27017/$(MONGO_DB)?authSource=admin"

---
apiVersion: v1
kind: Service
metadata:
  name: frontend-service
  namespace: log-anomaly
spec:
  selector:
    app: frontend
  ports:
    - protocol: TCP
      port: 8501
      targetPort: 8501
